APP_URL=http://localhost:8080
APP_NAME=Rockdesk
APP_DESC=Internal support desk
DEBUG_MODE=true

DB_HOST=db
DB_PORT=3306
DB_NAME=phpmon
DB_USER=phpmon
DB_PASS=phpmon
DB_ROOT_PASS=root

TICKET_AUTO_CLOSE_DAYS=14

# Active Directory / LDAPS authentication.
# Keep LDAP_PASSWORD out of git; provide it through your local .env or deployment secrets.
LDAP_ENABLED=false
LDAP_HOST=ad.example.local
LDAP_PORT=636
LDAP_BASE_DN=DC=example,DC=local
LDAP_USERNAME=CN=ldap-reader,OU=Service Accounts,DC=example,DC=local
LDAP_PASSWORD=
LDAP_USE_SSL=true
LDAP_USE_TLS=false
LDAP_TIMEOUT=5
LDAP_DOMAIN=example.local
LDAP_USER_FILTER_ATTRIBUTE=samaccountname
LDAP_TLS_REQUIRE_CERT=true

# Email notifications. Leave MAIL_ENABLED=false for local development without SMTP.
MAIL_ENABLED=false
MAILER_DSN=smtp://user:pass@mail.example.com:587?encryption=tls
MAIL_FROM_ADDRESS=support@example.com
MAIL_FROM_NAME=Rockdesk
INBOUND_MAIL_ADDRESS=support@example.com
INBOUND_MAIL_PLUS_ADDRESSING_ENABLED=false
INBOUND_MAIL_PLUS_DELIMITER=+
INBOUND_MAIL_ENABLED=false
INBOUND_MAIL_DRIVER=imap
INBOUND_IMAP_HOST=outlook.office365.com
INBOUND_IMAP_PORT=993
INBOUND_IMAP_ENCRYPTION=ssl
INBOUND_IMAP_USERNAME=support@example.com
INBOUND_IMAP_PASSWORD=
INBOUND_IMAP_MAILBOX=INBOX
INBOUND_IMAP_PROCESSED_MAILBOX=Processed
INBOUND_IMAP_FAILED_MAILBOX=Failed
INBOUND_IMAP_VALIDATE_CERT=true
INBOUND_IMAP_MAX_MESSAGES=25
